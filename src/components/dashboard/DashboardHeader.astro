---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<header class="mb-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-8">
  <p class="text-sm font-semibold uppercase tracking-wide text-emerald-600">Maoko Engineering</p>
  <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{title}</h1>
  <p class="mt-3 max-w-3xl text-sm text-slate-600 sm:text-base">{subtitle}</p>
</header>
