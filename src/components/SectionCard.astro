---
interface Props {
  id: string;
  title: string;
  description?: string;
}

const { id, title, description } = Astro.props;
---

<section id={id} class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
  <h2 class="text-xl font-semibold text-slate-900">{title}</h2>
  {description && <p class="mt-2 text-sm text-slate-600">{description}</p>}
  <div class="mt-4 space-y-4">
    <slot />
  </div>
</section>
