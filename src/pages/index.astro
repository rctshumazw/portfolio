---
import CategoryCard from '../components/dashboard/CategoryCard.astro';
import DashboardHeader from '../components/dashboard/DashboardHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    id: 'pumps',
    title: 'Pumps (Transfer & Circulation)',
    description: 'Capture pump equipment status, ammeter readings, visible flow checks, and actions taken.',
  },
  {
    id: 'control-panel',
    title: 'Control Panel',
    description: 'Record switch trips, meter functionality, HMI state, and any control notes.',
  },
  {
    id: 'pressure-readings',
    title: 'Pressure Readings',
    description: 'Track pressure values across key points in the treatment process.',
  },
  {
    id: 'tank-levels',
    title: 'Tank Levels',
    description: 'Log storage and process tank levels for operations visibility.',
  },
  {
    id: 'water-supply-table',
    title: 'Water Supply Table',
    description: 'Update source, quantity, and condition readings for incoming water supply.',
  },
  {
    id: 'primary-filter-maintenance',
    title: 'Primary Filter Maintenance',
    description: 'Document inspection, cleaning, and replacement activity for primary filtration.',
  },
  {
    id: 'probe-maintenance',
    title: 'Probe Maintenance',
    description: 'Report probe calibration, cleaning, and sensor status checks.',
  },
  {
    id: 'chemical-storage',
    title: 'Chemical Storage',
    description: 'Verify chemical levels, containment condition, labeling, and safety controls.',
  },
  {
    id: 'housekeeping',
    title: 'Housekeeping',
    description: 'Record cleanliness, safety hazards, and corrective actions in service areas.',
  },
];
---

<BaseLayout>
  <DashboardHeader
    title="Water Treatment Plant Service Reports"
    subtitle="Use this dashboard to quickly start a new field report or jump directly into a service category for focused updates."
  />

  <div class="mb-6">
    <a
      href="/reports/new"
      class="inline-flex items-center rounded-xl bg-blue-700 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2"
    >
      New Service Report
    </a>
  </div>

  <section aria-label="Service report categories" class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
    {
      categories.map((category) => (
        <CategoryCard
          title={category.title}
          description={category.description}
          href={`/reports/new#${category.id}`}
        />
      ))
    }
  </section>
</BaseLayout>
